	local char = LocalPlayer and LocalPlayer.Character;
	local myHRP = char and char:FindFirstChild("HumanoidRootPart");
	if not myHRP then
		return nil;
	end
	local vp = Camera.ViewportSize;
	local cx, cy = vp.X * 0.5, vp.Y * 0.5;
	local fovSq = aimbotFOV * aimbotFOV;
	local best, bestDistSq = nil, math.huge;
	for _, e in ipairs(getCharacters()) do
		if not (e.hp and (e.hp <= 0)) then
			local bone = e.model:FindFirstChild(aimbotBone) or e.model:FindFirstChild("HumanoidRootPart") or e.hrp;
			if bone then
				local pos, onScreen = WorldToScreen(bone.Position);
				if onScreen then
					local dx = pos.X - cx;
					local dy = pos.Y - cy;
					local dSq = (dx * dx) + (dy * dy);
					if ((dSq < fovSq) and (dSq < bestDistSq)) then
						bestDistSq = dSq;
						best = bone;
					end
				end
			end
		end
	end
	return best;
end
local function doAimbot()
	if not aimbotEnabled then
		return;
	end
	if not ismouse2pressed() then
		return;
	end
	local target = getNearestNPC();
	if not target then
		return;
	end
	local pos, onScreen = WorldToScreen(target.Position);
	if not onScreen then
		return;
	end
	local vp = Camera.ViewportSize;
	local cx = vp.X * 0.5;
	local cy = vp.Y * 0.5;
	local moveX = math.floor((pos.X - cx) * aimbotSmooth);
	local moveY = math.floor((pos.Y - cy) * aimbotSmooth);
	if ((math.abs(moveX) > 0) or (math.abs(moveY) > 0)) then
		mousemoverel(moveX, moveY);
	end
end
