local function rebuildAI()
	local char = LocalPlayer and LocalPlayer.Character;
	local myHRP = char and char:FindFirstChild("HumanoidRootPart");
	local myPos = myHRP and myHRP.Position;
	local distSqMax = aiDistMax ^ 2;
	local raw = {};
	for _, e in ipairs(getCharacters()) do
		local ok, rootPos = pcall(function()
			return e.hrp.Position;
		end);
		if (ok and rootPos) then
			local dx = (myPos and (myPos.X - rootPos.X)) or 0;
			local dy = (myPos and (myPos.Y - rootPos.Y)) or 0;
			local dz = (myPos and (myPos.Z - rootPos.Z)) or 0;
			local distSq = (dx * dx) + (dy * dy) + (dz * dz);
			if (distSq <= distSqMax) then
				local d = math.sqrt(distSq);
				local healthRatio, healthColor;
				if (e.hp and e.maxhp and (e.maxhp > 0)) then
					healthRatio = math.clamp(e.hp / e.maxhp, 0, 1);
					healthColor = hpColor(healthRatio);
				end
				raw[#raw + 1] = {kind="ai",part=e.hrp,name=e.model.Name,distText=string.format("%dm", math.floor(d)),healthRatio=healthRatio,healthColor=healthColor,weapon=e.weapon,_distSq=distSq};
			end
		end
	end
	table.sort(raw, function(a, b)
		return a._distSq < b._distSq;
	end);
	local out = {};
	for _, v in ipairs(raw) do
		if (#out >= MAX_SLOTS) then
			break;
		end
		out[#out + 1] = v;
	end
	espItems = out;
end
